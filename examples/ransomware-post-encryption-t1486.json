      "businessObjectives": {
        "bo-001": {
          "id": "bo-001",
          "scope": "Entire encrypted infrastructure and affected business operations",
          "purpose": "Restore business operations and data availability after successful ransomware encryption",
          "viewpoint": "Business Recovery and Continuity",
          "context": "Full encryption has halted operations; recovery path must balance speed, cost, and risk of re-attack",
          "relatedObjectiveIds": ["bo-002", "bo-003"],
          "paragonId": null
        },
        "bo-002": {
          "id": "bo-002",
          "scope": "Organizational security posture and controls",
          "purpose": "Prevent recurrence by addressing root cause and hardening defenses",
          "viewpoint": "Security Improvement",
          "context": "Organizations that pay ransom are frequently targeted again; security posture must improve regardless of recovery path chosen",
          "relatedObjectiveIds": ["bo-001", "bo-003"],
          "paragonId": null
        },
        "bo-003": {
          "id": "bo-003",
          "scope": "Data integrity and backup systems",
          "purpose": "Ensure reliable data recovery capability independent of threat actor cooperation",
          "viewpoint": "Disaster Recovery",
          "context": "Decryptors may not work (ProLock example); backups are the only guaranteed recovery path",
          "relatedObjectiveIds": ["bo-001"],
          "paragonId": null
        }
      },
      "securityMeasurementGoals": {
        "smg-001": {
          "id": "smg-001",
          "viewpoint": "IT Service Management",
          "context": "Recovery time directly determines business impact magnitude after encryption",
          "scope": "All encrypted systems and services",
          "purpose": "Measure and minimize time to full operational recovery",
          "focus": "Time from encryption event to full service restoration",
          "criteria": "Critical services restored within RTO; full recovery within 72 hours",
          "businessObjectiveIds": ["bo-001"],
          "paragonId": null
        },
        "smg-002": {
          "id": "smg-002",
          "viewpoint": "Security Operations",
          "context": "Post-encryption, threat actors may still be present and active",
          "scope": "All network segments and endpoints",
          "purpose": "Verify complete threat actor eviction before recovery begins",
          "focus": "Confirmation that no active threat actor access remains",
          "criteria": "Zero indicators of active threat actor presence for 48+ hours before recovery",
          "businessObjectiveIds": ["bo-002"],
          "paragonId": null
        }
      },
      "securityMetrics": {
        "sm-001": {
          "id": "sm-001",
          "description": "Time from encryption event detection to full critical service restoration",
          "goal": "Minimize business impact by achieving fastest possible recovery",
          "baseMeasurementIds": ["bm-001"],
          "method": "Track time from initial encryption alert to confirmed restoration of all critical services",
          "measurementFunction": "restoration_timestamp - encryption_detection_timestamp",
          "interpretation": "Sub-72h recovery indicates strong DR capability; longer durations require DR process improvement",
          "reporting": "Post-incident report; quarterly DR readiness assessment",
          "smgIds": ["smg-001"]
        },
        "sm-002": {
          "id": "sm-002",
          "description": "Days between containment completion and last observed indicator of threat actor activity",
          "goal": "Ensure complete threat actor eviction before rebuilding infrastructure",
          "baseMeasurementIds": ["bm-002"],
          "method": "Monitor for any C2 callbacks, unauthorized access, or persistence activation after containment",
          "measurementFunction": "days_since_last_threat_activity",
          "interpretation": "48+ hours of silence indicates successful eviction; any activity requires re-investigation",
          "reporting": "Daily during active response; final confirmation in incident closure report",
          "smgIds": ["smg-002"]
        }
