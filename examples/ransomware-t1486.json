        "bo-003": {
          "id": "bo-003",
          "scope": "Backup infrastructure and disaster recovery systems",
          "purpose": "Guarantee the ability to restore systems to a known-good state within defined timeframes",
          "viewpoint": "Disaster Recovery and Resilience",
