      },
      "securityMeasurementGoals": {
        "smg-001": {
          "id": "smg-001",
          "viewpoint": "Security Operations Center",
          "context": "Password spraying distributes attempts across accounts to evade per-account lockout detection",
          "scope": "All authentication logs from identity providers, VPN, and cloud services",
          "purpose": "Detect distributed credential attacks that bypass single-account threshold alerting",
          "focus": "Correlation of failed authentication patterns across multiple accounts",
          "criteria": "Spraying campaigns detected within 50 failed attempts across the environment",
          "businessObjectiveIds": ["bo-001", "bo-002"],
          "paragonId": null
        },
        "smg-002": {
          "id": "smg-002",
          "viewpoint": "Identity Engineering",
          "context": "Account lockout is a primary defense but must balance security with usability",
          "scope": "Lockout policies across all authentication systems",
          "purpose": "Measure the effectiveness of lockout policies in containing spraying attempts",
          "focus": "Lockout trigger speed and automated response actions",
          "criteria": "Targeted accounts locked within 30 seconds of spraying detection",
          "businessObjectiveIds": ["bo-002", "bo-003"],
          "paragonId": null
        },
        "smg-003": {
          "id": "smg-003",
          "viewpoint": "Security Governance",
          "context": "MFA renders compromised passwords insufficient for account access",
          "scope": "All user and service accounts across the enterprise",
          "purpose": "Track multi-factor authentication deployment as a mitigation against credential attacks",
          "focus": "Percentage of accounts protected by MFA across all authentication endpoints",
