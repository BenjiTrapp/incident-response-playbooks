    "symbiosis": {
      "businessObjectives": {
        "bo-001": {
          "id": "bo-001",
          "scope": "All employee web browsing activity and web-dependent workflows",
          "purpose": "Enable safe web browsing without exposing endpoints to drive-by exploitation",
          "viewpoint": "Workforce Productivity and Security",
          "context": "Users require web access for daily work; drive-by compromises exploit this access without user interaction",
          "relatedObjectiveIds": ["bo-002"],
          "paragonId": null
        },
        "bo-002": {
          "id": "bo-002",
          "scope": "Network perimeter and web traffic inspection infrastructure",
          "purpose": "Maintain network boundary integrity by preventing malicious inbound content from reaching endpoints",
          "viewpoint": "Network Security Architecture",
          "context": "Drive-by compromises deliver exploits through legitimate web traffic, requiring deep content inspection",
          "relatedObjectiveIds": ["bo-001", "bo-003"],
          "paragonId": null
        },
        "bo-003": {
          "id": "bo-003",
          "scope": "Browser and plugin vulnerability surface across all managed endpoints",
          "purpose": "Prevent successful exploitation of browser vulnerabilities by drive-by kits",
          "viewpoint": "Vulnerability Management",
          "context": "Exploit kits target known browser and plugin vulnerabilities; patching and exploit mitigation are primary defenses",
          "relatedObjectiveIds": ["bo-001"],
          "paragonId": null
        }
      },
      "securityMeasurementGoals": {
        "smg-001": {
          "id": "smg-001",
          "viewpoint": "Web Security Engineering",
          "context": "Web filtering must block access to known malicious sites and newly identified threats",
          "scope": "All web proxy and DNS filtering infrastructure",
          "purpose": "Measure the coverage and effectiveness of web content filtering against malicious URLs",
          "focus": "URL categorization accuracy, threat intelligence feed coverage, and blocking rate",
          "criteria": "≥99% of known malicious URLs blocked before user access",
          "businessObjectiveIds": ["bo-001", "bo-002"],
          "paragonId": null
        },
        "smg-002": {
          "id": "smg-002",
          "viewpoint": "Endpoint Security Architecture",
          "context": "Browser isolation prevents exploit code from executing on the endpoint even if the user visits a malicious page",
          "scope": "Browser isolation technology deployed to high-risk user populations",
          "purpose": "Evaluate the effectiveness of browser isolation in preventing drive-by exploitation",
          "focus": "Isolation coverage, rendering fidelity, and exploit containment rate",
          "criteria": "100% of high-risk browsing sessions rendered in isolation with zero endpoint impact",
          "businessObjectiveIds": ["bo-001", "bo-003"],
          "paragonId": null
        },
        "smg-003": {
          "id": "smg-003",
          "viewpoint": "Security Operations Center",
          "context": "Exploit attempts that bypass filtering must be detected through behavioral analysis and network signatures",
          "scope": "IDS/IPS, EDR, and network traffic analysis systems",
          "purpose": "Measure detection rate of browser exploit attempts in network and endpoint telemetry",
          "focus": "Exploit kit signature detection, anomalous browser process behavior, and shellcode execution attempts",
          "criteria": "≥95% of exploit attempts detected with mean time to alert under 30 seconds",
          "businessObjectiveIds": ["bo-002", "bo-003"],
          "paragonId": null
        }
      },
      "securityMetrics": {
        "sm-001": {
          "id": "sm-001",
          "description": "Percentage of malicious URLs blocked by web filtering infrastructure before user access",
          "goal": "Prevent users from reaching exploit kit landing pages and malicious content delivery sites",
          "baseMeasurementIds": ["bm-001", "bm-002"],
